                <mxCell id="80" value="A replay of this Model should result in a subset of the language of the Sensor Topology" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
                    <mxGeometry x="-70" y="380" width="60" height="150" as="geometry"/>
                </mxCell>
